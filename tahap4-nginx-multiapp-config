#!/bin/bash

################################################################################
# TAHAP 4: Nginx Multi-Application Configuration
# Ubuntu 24.04 LTS
#
# Script ini mengkonfigurasi:
# - Path-based routing (domain.com/app1, domain.com/app2)
# - Subdomain routing (app1.domain.com, app2.domain.com)
# - Port-based proxying untuk development
# - SSL certificate readiness
#
# Usage: bash tahap4-nginx-multiapp-config.sh
################################################################################

set -e

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Functions
print_header() {
    echo -e "\n${BLUE}===============================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}===============================================${NC}\n"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${CYAN}ℹ $1${NC}"
}

# Check if running with appropriate privileges
if [[ $EUID -ne 0 ]]; then
    print_error "Script ini harus dijalankan dengan sudo"
    exit 1
fi

print_header "TAHAP 4: Nginx Multi-Application Configuration"

# ============================================================================
# SECTION 1: Collect Configuration Information
# ============================================================================
print_header "1. Informasi Konfigurasi"

# Get domain
read -p "Domain aplikasi [default: domainaplikasimu.id]: " DOMAIN
DOMAIN=${DOMAIN:-domainaplikasimu.id}

print_success "Domain: $DOMAIN"

# Get VPS IP address
VPS_IP=$(hostname -I | awk '{print $1}')
read -p "VPS Public IP [$VPS_IP]: " INPUT_IP
VPS_IP=${INPUT_IP:-$VPS_IP}

print_success "VPS IP: $VPS_IP"

# Determine routing strategy
echo -e "\n${YELLOW}Pilih strategi routing:${NC}"
echo "1) Path-based (domain.com/app1, domain.com/app2)"
echo "2) Subdomain-based (app1.domain.com, app2.domain.com)"
echo "3) Hybrid (kombinasi keduanya)"
read -p "Pilihan [default: 3]: " ROUTING_STRATEGY
ROUTING_STRATEGY=${ROUTING_STRATEGY:-3}

case $ROUTING_STRATEGY in
    1) ROUTING_TYPE="path" ;;
    2) ROUTING_TYPE="subdomain" ;;
    3) ROUTING_TYPE="hybrid" ;;
    *) ROUTING_TYPE="hybrid" ;;
esac

print_success "Strategi routing: $ROUTING_TYPE"

# Get development user
read -p "Username development user [default: devel_me]: " DEVEL_USER
DEVEL_USER=${DEVEL_USER:-devel_me}

if ! id "$DEVEL_USER" &>/dev/null; then
    print_error "User '$DEVEL_USER' tidak ditemukan"
    exit 1
fi

print_success "Development user: $DEVEL_USER"

# Get number of applications
read -p "Jumlah aplikasi yang akan dikonfigurasi [default: 5]: " NUM_APPS
NUM_APPS=${NUM_APPS:-5}

print_success "Jumlah aplikasi: $NUM_APPS"

# ============================================================================
# SECTION 2: Create Nginx Configuration Directories
# ============================================================================
print_header "2. Setup Direktori Nginx"

mkdir -p /etc/nginx/sites-available
mkdir -p /etc/nginx/sites-enabled
mkdir -p /etc/nginx/conf.d
mkdir -p /etc/nginx/includes
mkdir -p /var/log/nginx/apps

print_success "Nginx directories siap"

# ============================================================================
# SECTION 3: Create Common Nginx Includes
# ============================================================================
print_header "3. Membuat Common Nginx Includes"

# Common proxy headers
cat > /etc/nginx/includes/proxy-params.conf << 'EOF'
# Common reverse proxy parameters
proxy_set_header Host $host;
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;
proxy_set_header X-Forwarded-Host $server_name;
proxy_set_header X-Forwarded-Port $server_port;

# Connection settings
proxy_http_version 1.1;
proxy_set_header Connection "";
proxy_set_header Upgrade $http_upgrade;
proxy_set_header Connection "upgrade";

# Timeouts
proxy_connect_timeout 60s;
proxy_send_timeout 60s;
proxy_read_timeout 60s;

# Buffering
proxy_buffering on;
proxy_buffer_size 4k;
proxy_buffers 8 4k;
proxy_busy_buffers_size 8k;
EOF

print_success "Common proxy parameters included"

# Security headers
cat > /etc/nginx/includes/security-headers.conf << 'EOF'
# Security headers
add_header X-Frame-Options "SAMEORIGIN" always;
add_header X-Content-Type-Options "nosniff" always;
add_header X-XSS-Protection "1; mode=block" always;
add_header Referrer-Policy "strict-origin-when-cross-origin" always;
add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
EOF

print_success "Security headers configured"

# CORS for API
cat > /etc/nginx/includes/cors-headers.conf << 'EOF'
# CORS headers (adjust Origin as needed)
add_header Access-Control-Allow-Origin "$http_origin" always;
add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
add_header Access-Control-Allow-Headers "Authorization, Content-Type" always;

if ($request_method = 'OPTIONS') {
    return 204;
}
EOF

print_success "CORS headers configured"

# ============================================================================
# SECTION 4: Create Main Domain Configuration
# ============================================================================
print_header "4. Membuat Main Domain Configuration"

cat > /etc/nginx/sites-available/main-domain << EOF
# Main domain configuration
# Supports path-based and subdomain routing

upstream api_backend {
    # API backend servers
    server localhost:3000;
}

upstream frontend_app {
    # Frontend servers
    server localhost:3001;
}

# Redirect HTTP ke HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name $DOMAIN www.$DOMAIN *.${DOMAIN};
    
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    
    location / {
        return 301 https://\$server_name\$request_uri;
    }
}

# HTTPS Server Block
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    
    server_name $DOMAIN www.$DOMAIN;
    
    # SSL certificates (akan dikonfigurasi di tahap 5)
    # ssl_certificate /etc/letsencrypt/live/$DOMAIN/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/$DOMAIN/privkey.pem;
    
    # Logging
    access_log /var/log/nginx/main-domain.access.log combined buffer=32k flush=1m;
    error_log /var/log/nginx/main-domain.error.log warn;
    
    include /etc/nginx/includes/security-headers.conf;
    
    # Root location
    location = / {
        proxy_pass http://localhost:3001;
        include /etc/nginx/includes/proxy-params.conf;
    }
    
    # API routes
    location /api/ {
        proxy_pass http://localhost:3000;
        include /etc/nginx/includes/proxy-params.conf;
        include /etc/nginx/includes/cors-headers.conf;
    }
}

# Subdomain wildcard configuration (untuk app1.domain.com, app2.domain.com, etc)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    
    server_name ~^(?<app>.+)\.$DOMAIN\$;
    
    # SSL certificates
    # ssl_certificate /etc/letsencrypt/live/$DOMAIN/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/$DOMAIN/privkey.pem;
    
    # Logging per subdomain
    access_log /var/log/nginx/apps/\$app.access.log combined buffer=32k flush=1m;
    error_log /var/log/nginx/apps/\$app.error.log warn;
    
    include /etc/nginx/includes/security-headers.conf;
    
    # Routing subdomain ke port berbeda
    location / {
        # Port assignment: app1 -> 3001, app2 -> 3002, etc
        set \$port 3000;
        
        if (\$app = "app1") { set \$port 3001; }
        if (\$app = "app2") { set \$port 3002; }
        if (\$app = "app3") { set \$port 3003; }
        if (\$app = "app4") { set \$port 3004; }
        if (\$app = "app5") { set \$port 3005; }
        # Tambahkan lebih banyak sesuai kebutuhan
        
        proxy_pass http://localhost:\$port;
        include /etc/nginx/includes/proxy-params.conf;
    }
}
EOF

print_success "Main domain configuration dibuat"

# ============================================================================
# SECTION 5: Create Path-Based Application Templates
# ============================================================================
print_header "5. Membuat Path-Based Application Templates"

for ((i=1; i<=NUM_APPS; i++)); do
    APP_NAME="aplikasi$i"
    APP_PORT=$((3000 + i))
    
    cat > /etc/nginx/sites-available/app-${APP_NAME}-path << EOF
# Path-based configuration untuk $APP_NAME
# URL: $DOMAIN/$APP_NAME

upstream ${APP_NAME}_upstream {
    server localhost:$APP_PORT;
}

server {
    listen 80;
    listen [::]:80;
    server_name $DOMAIN www.$DOMAIN;
    
    location /$APP_NAME/ {
        proxy_pass http://${APP_NAME}_upstream/;
        include /etc/nginx/includes/proxy-params.conf;
        
        # Rewrite path untuk aplikasi
        rewrite ^/$APP_NAME/(.*)\$ /\$1 break;
    }
}
EOF

done

print_success "Path-based configuration templates dibuat untuk $NUM_APPS aplikasi"

# ============================================================================
# SECTION 6: Create Subdomain-Based Application Templates
# ============================================================================
print_header "6. Membuat Subdomain-Based Application Templates"

for ((i=1; i<=NUM_APPS; i++)); do
    APP_NAME="aplikasi$i"
    APP_PORT=$((3000 + i))
    
    cat > /etc/nginx/sites-available/app-${APP_NAME}-subdomain << EOF
# Subdomain configuration untuk $APP_NAME
# URL: ${APP_NAME}.$DOMAIN

upstream ${APP_NAME}_upstream {
    server localhost:$APP_PORT;
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name ${APP_NAME}.$DOMAIN;
    
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    
    location / {
        return 301 https://\$server_name\$request_uri;
    }
}

# HTTPS server block
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ${APP_NAME}.$DOMAIN;
    
    # SSL certificates (akan dikonfigurasi di tahap 5)
    # ssl_certificate /etc/letsencrypt/live/${APP_NAME}.$DOMAIN/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/${APP_NAME}.$DOMAIN/privkey.pem;
    
    # Logging
    access_log /var/log/nginx/apps/${APP_NAME}.access.log combined buffer=32k flush=1m;
    error_log /var/log/nginx/apps/${APP_NAME}.error.log warn;
    
    include /etc/nginx/includes/security-headers.conf;
    
    # Proxy ke aplikasi
    location / {
        proxy_pass http://${APP_NAME}_upstream;
        include /etc/nginx/includes/proxy-params.conf;
    }
}
EOF

done

print_success "Subdomain-based configuration templates dibuat untuk $NUM_APPS aplikasi"

# ============================================================================
# SECTION 7: Create Configuration Mapping Document
# ============================================================================
print_header "7. Membuat Application Configuration Mapping"

cat > /etc/nginx/apps-config.map << EOF
# Application Configuration Mapping
# Generated: $(date)
# Domain: $DOMAIN
# Routing Strategy: $ROUTING_TYPE

## Application Port Allocation

EOF

for ((i=1; i<=NUM_APPS; i++)); do
    APP_NAME="aplikasi$i"
    APP_PORT=$((3000 + i))
    echo "aplikasi$i: port $APP_PORT | path: /$APP_NAME | subdomain: ${APP_NAME}.$DOMAIN" >> /etc/nginx/apps-config.map
done

cat >> /etc/nginx/apps-config.map << EOF

## Enable Application Configuration

To enable an application, run:
  sudo ln -s /etc/nginx/sites-available/app-\${APP_NAME}-${ROUTING_TYPE} /etc/nginx/sites-enabled/

Then reload Nginx:
  sudo systemctl reload nginx

## Port Reference

Main domain (port 3000-3001): $DOMAIN
Subdomains (port 3001+): app.${DOMAIN}

EOF

print_success "Configuration mapping created"
cat /etc/nginx/apps-config.map

# ============================================================================
# SECTION 8: Enable Main Domain
# ============================================================================
print_header "8. Mengaktifkan Main Domain Configuration"

# Remove default if exists
if [ -L /etc/nginx/sites-enabled/default ]; then
    rm /etc/nginx/sites-enabled/default
fi

# Enable main domain
ln -sf /etc/nginx/sites-available/main-domain /etc/nginx/sites-enabled/main-domain

print_success "Main domain configuration enabled"

# ============================================================================
# SECTION 9: Test Nginx Configuration
# ============================================================================
print_header "9. Test Nginx Configuration"

if nginx -t 2>&1 | grep -q "successful"; then
    print_success "Nginx configuration test passed"
else
    print_error "Nginx configuration test failed"
    nginx -t
    exit 1
fi

# Reload Nginx
systemctl reload nginx
print_success "Nginx reloaded"

# ============================================================================
# SECTION 10: Create Helper Scripts
# ============================================================================
print_header "10. Membuat Helper Scripts"

# Script untuk enable aplikasi
cat > /home/$DEVEL_USER/enable-app.sh << 'SCRIPT_EOF'
#!/bin/bash

# Helper script untuk enable aplikasi Nginx config
# Usage: ./enable-app.sh aplikasi1 subdomain

APP_NAME=$1
ROUTING_TYPE=${2:-subdomain}

if [ -z "$APP_NAME" ]; then
    echo "Usage: $0 <app_name> [path|subdomain|hybrid]"
    echo "Example: $0 aplikasi1 subdomain"
    exit 1
fi

ROUTING_TYPE=${ROUTING_TYPE:-subdomain}

CONFIG_FILE="/etc/nginx/sites-available/app-${APP_NAME}-${ROUTING_TYPE}"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Config file not found: $CONFIG_FILE"
    exit 1
fi

# Enable config
sudo ln -sf "$CONFIG_FILE" /etc/nginx/sites-enabled/

# Test configuration
if sudo nginx -t 2>&1 | grep -q "successful"; then
    echo "✓ Configuration test passed"
    sudo systemctl reload nginx
    echo "✓ Nginx reloaded"
    echo "✓ Application enabled: $APP_NAME (routing: $ROUTING_TYPE)"
else
    echo "✗ Configuration test failed"
    sudo nginx -t
    exit 1
fi
SCRIPT_EOF

chmod +x /home/$DEVEL_USER/enable-app.sh
chown $DEVEL_USER:$DEVEL_USER /home/$DEVEL_USER/enable-app.sh

print_success "Helper script created: /home/$DEVEL_USER/enable-app.sh"

# Script untuk list aplikasi
cat > /home/$DEVEL_USER/list-apps.sh << 'SCRIPT_EOF'
#!/bin/bash

# List all configured applications
echo "Configured Applications:"
echo "======================="
ls -1 /etc/nginx/sites-available/app-* 2>/dev/null | sed 's/.*app-//' | sed 's/-path$//' | sed 's/-subdomain$//' | sort -u
SCRIPT_EOF

chmod +x /home/$DEVEL_USER/list-apps.sh
chown $DEVEL_USER:$DEVEL_USER /home/$DEVEL_USER/list-apps.sh

print_success "Helper script created: /home/$DEVEL_USER/list-apps.sh"

# ============================================================================
# SECTION 11: Verification & Summary
# ============================================================================
print_header "11. Verifikasi dan Summary"

echo -e "\n${BLUE}Nginx Status:${NC}\n"
systemctl status nginx --no-pager | head -10 | sed 's/^/    /'

echo -e "\n${BLUE}Enabled Sites:${NC}\n"
ls -1 /etc/nginx/sites-enabled/ | sed 's/^/    /'

echo -e "\n${BLUE}Application Configuration:${NC}\n"
echo "    Domain:          $DOMAIN"
echo "    VPS IP:          $VPS_IP"
echo "    Routing Type:    $ROUTING_TYPE"
echo "    Dev User:        $DEVEL_USER"
echo "    Total Apps:      $NUM_APPS"

echo -e "\n${BLUE}Port Allocation:${NC}\n"
for ((i=1; i<=5; i++)); do
    APP_NAME="aplikasi$i"
    APP_PORT=$((3000 + i))
    echo "    ${APP_NAME}: localhost:$APP_PORT"
done
if [ $NUM_APPS -gt 5 ]; then
    echo "    ... and more"
fi

echo -e "\n${BLUE}Helper Scripts:${NC}\n"
echo "    Enable app:      /home/$DEVEL_USER/enable-app.sh <app_name> [subdomain|path]"
echo "    List apps:       /home/$DEVEL_USER/list-apps.sh"

echo -e "\n${BLUE}Next Steps:${NC}\n"
echo "    1. Enable aplikasi dengan helper script atau manual"
echo "    2. Deploy aplikasi ke ~/apps/aplikasi{1..N}"
echo "    3. Konfigurasi PM2 untuk setiap aplikasi"
echo "    4. Setup SSL/HTTPS di tahap berikutnya"

# ============================================================================
# SECTION 12: Create Setup Instructions
# ============================================================================
print_header "12. Instruksi Setup Aplikasi"

cat > /home/$DEVEL_USER/NGINX_SETUP_GUIDE.md << EOF
# Nginx Multi-Application Setup Guide

## Informasi Konfigurasi

- **Domain**: $DOMAIN
- **VPS IP**: $VPS_IP
- **Routing Strategy**: $ROUTING_TYPE
- **Total Applications**: $NUM_APPS

## Mengaktifkan Aplikasi

### Opsi 1: Menggunakan Helper Script
\`\`\`bash
~/enable-app.sh aplikasi1 subdomain
\`\`\`

### Opsi 2: Manual Enablement
\`\`\`bash
# Untuk subdomain-based
sudo ln -s /etc/nginx/sites-available/app-aplikasi1-subdomain /etc/nginx/sites-enabled/

# Atau untuk path-based
sudo ln -s /etc/nginx/sites-available/app-aplikasi1-path /etc/nginx/sites-enabled/

# Test dan reload
sudo nginx -t
sudo systemctl reload nginx
\`\`\`

## Port Allocation

EOF

for ((i=1; i<=NUM_APPS; i++)); do
    APP_NAME="aplikasi$i"
    APP_PORT=$((3000 + i))
    echo "- ${APP_NAME}: port $APP_PORT" >> /home/$DEVEL_USER/NGINX_SETUP_GUIDE.md
done

cat >> /home/$DEVEL_USER/NGINX_SETUP_GUIDE.md << EOF

## Access URLs

### Subdomain Routing
- app1.$DOMAIN (port 3001)
- app2.$DOMAIN (port 3002)
- etc.

### Path-Based Routing
- $DOMAIN/aplikasi1
- $DOMAIN/aplikasi2
- etc.

## Troubleshooting

### Check Nginx Status
\`\`\`bash
systemctl status nginx
\`\`\`

### Check Logs
\`\`\`bash
# Access logs
tail -f /var/log/nginx/apps/aplikasi1.access.log

# Error logs
tail -f /var/log/nginx/apps/aplikasi1.error.log
\`\`\`

### Test Configuration
\`\`\`bash
sudo nginx -t
\`\`\`

### Reload Nginx
\`\`\`bash
sudo systemctl reload nginx
\`\`\`
EOF

chown $DEVEL_USER:$DEVEL_USER /home/$DEVEL_USER/NGINX_SETUP_GUIDE.md
print_success "Setup guide created: /home/$DEVEL_USER/NGINX_SETUP_GUIDE.md"

print_header "✓ TAHAP 4 Selesai!"

echo -e "${GREEN}Nginx multi-application configuration berhasil dikonfigurasi.${NC}"
echo -e "Lanjut ke tahap berikutnya dengan perintah:\n"
echo -e "  ${YELLOW}bash tahap5-ssl-https-setup.sh${NC}\n"
