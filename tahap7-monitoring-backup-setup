chmod +x "$DEVEL_HOME/backup-database.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/backup-database.sh"

print_success "Database backup template created"

# ============================================================================
# SECTION 5: Setup Automated Backup Scheduling
# ============================================================================
print_header "5. Setup Automated Backup Scheduling (Cron)"

CRON_ENTRY="0 2 * * * $DEVEL_HOME/backup-configs.sh >> /var/log/backups.log 2>&1"

# Check if cron entry already exists
if (crontab -u $DEVEL_USER -l 2>/dev/null | grep -q "backup-configs.sh"); then
    print_warning "Backup cron job sudah ada"
else
    # Add cron entry
    (crontab -u $DEVEL_USER -l 2>/dev/null; echo "$CRON_ENTRY") | crontab -u $DEVEL_USER -
    print_success "Automated backup cron job ditambahkan (daily at 2 AM)"
fi

# Create log rotation for backup logs
cat > /etc/logrotate.d/backups << EOF
/var/log/backups.log {
    daily
    rotate 30
    compress
    delaycompress
    notifempty
    missingok
}
EOF

print_success "Backup log rotation configured"

# ============================================================================
# SECTION 6: Create Log Management Scripts
# ============================================================================
print_header "6. Create Log Management Scripts"

# Aggregate all logs script
cat > "$DEVEL_HOME/view-logs.sh" << 'SCRIPT_EOF'
#!/bin/bash
# View and aggregate application logs

APP_NAME=$1
LINES=${2:-50}

if [ -z "$APP_NAME" ]; then
    echo "Available log files:"
    echo "===================="
    ls -lh ~/apps/logs/ | tail -n +2 | awk '{print $9}' | sed 's/^/  /'
    echo ""
    echo "Usage: $0 <app_name|all> [lines]"
    echo "Example: $0 aplikasi1 100"
    exit 0
fi

if [ "$APP_NAME" = "all" ]; then
    echo "Last $LINES lines from all application logs:"
    echo "=========================================="
    echo ""
    for logfile in ~/apps/logs/*.log; do
        echo "Log: $(basename $logfile)"
        echo "---"
        tail -n $LINES "$logfile"
        echo ""
    done
else
    APP_DIR="$HOME/apps/$APP_NAME"
    if [ ! -d "$APP_DIR" ]; then
        echo "Application not found: $APP_NAME"
        exit 1
    fi
    
    echo "Application: $APP_NAME"
    echo "Last $LINES lines from logs:"
    echo "=========================================="
    echo ""
    
    echo "Standard Output Log:"
    tail -n $LINES "$HOME/apps/logs/${APP_NAME}.out.log"
    echo ""
    
    echo "Error Log:"
    tail -n $LINES "$HOME/apps/logs/${APP_NAME}.error.log"
fi
SCRIPT_EOF

chmod +x "$DEVEL_HOME/view-logs.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/view-logs.sh"

print_success "Log viewing script created"

# ============================================================================
# SECTION 7: Create System Alert Script
# ============================================================================
print_header "7. Create System Alert Monitoring"

# Alert threshold checker
cat > "$DEVEL_HOME/check-thresholds.sh" << EOFTHRESHOLD
#!/bin/bash
# Check system thresholds and alert

EMAIL="$ALERT_EMAIL"
HOSTNAME=\$(hostname)
TIMESTAMP=\$(date '+%Y-%m-%d %H:%M:%S')

# Thresholds
CPU_THRESHOLD=80
MEM_THRESHOLD=80
DISK_THRESHOLD=85

# Get current values
CPU_USAGE=\$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - \$8}' | cut -d'.' -f1)
MEM_PERCENT=\$(free | grep Mem | awk '{printf("%.0f", (\$3/\$2)*100)}')
DISK_USAGE=\$(df / | tail -1 | awk '{print \$5}' | cut -d'%' -f1)

# Check thresholds
ALERT_MESSAGE=""

if [ \$CPU_USAGE -gt \$CPU_THRESHOLD ]; then
    ALERT_MESSAGE="\${ALERT_MESSAGE}⚠ HIGH CPU USAGE: \${CPU_USAGE}%\n"
fi

if [ \$MEM_PERCENT -gt \$MEM_THRESHOLD ]; then
    ALERT_MESSAGE="\${ALERT_MESSAGE}⚠ HIGH MEMORY USAGE: \${MEM_PERCENT}%\n"
fi

if [ \$DISK_USAGE -gt \$DISK_THRESHOLD ]; then
    ALERT_MESSAGE="\${ALERT_MESSAGE}⚠ HIGH DISK USAGE: \${DISK_USAGE}%\n"
fi

# Send alert if threshold exceeded
if [ -n "\$ALERT_MESSAGE" ]; then
    echo "Alert Email Would Be Sent:"
    echo "=========================="
    echo -e "\$ALERT_MESSAGE"
    
    # Uncomment to actually send email
    # echo -e "\$ALERT_MESSAGE" | mail -s "System Alert: \$HOSTNAME" "\$EMAIL"
fi
EOFTHRESHOLD

chmod +x "$DEVEL_HOME/check-thresholds.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/check-thresholds.sh"

print_success "Threshold checker script created"

# ============================================================================
# SECTION 8: Create Monitoring Dashboard Script
# ============================================================================
print_header "8. Create Monitoring Dashboard"

cat > "$DEVEL_HOME/dashboard.sh" << 'SCRIPT_EOF'
#!/bin/bash
# Real-time VPS monitoring dashboard

while true; do
    clear
    
    echo "╔════════════════════════════════════════════════════════════════╗"
    echo "║         VPS Monitoring Dashboard                               ║"
    echo "║         $(date '+%Y-%m-%d %H:%M:%S')                                  ║"
    echo "╚════════════════════════════════════════════════════════════════╝"
    echo ""
    
    # System Info
    echo "System Information:"
    uptime | sed 's/^/  /'
    echo ""
    
    # Resource Usage
    echo "Resource Usage:"
    free -h | grep Mem | awk '{printf "  Memory: %s / %s (%.1f%%)\n", $3, $2, ($3/$2)*100}'
    df -h / | tail -1 | awk '{printf "  Disk:   %s / %s (%.1f%%)\n", $3, $2, ($3/$2)*100}'
    echo ""
    
    # Services Status
    echo "Services Status:"
    echo -n "  Nginx:  "
    systemctl is-active nginx > /dev/null 2>&1 && echo "✓ Running" || echo "✗ Stopped"
    echo -n "  PM2:    "
    pm2 status > /dev/null 2>&1 && echo "✓ Running" || echo "✗ Stopped"
    echo ""
    
    # PM2 Applications
    echo "PM2 Applications ($(pm2 list 2>/dev/null | grep -c 'online' || echo '0') running):"
    pm2 list 2>/dev/null | tail -n +2 | head -10 | sed 's/^/  /' || echo "  No applications running"
    echo ""
    
    # Recent Errors
    echo "Recent Application Errors:"
    find ~/apps/logs -name "*.error.log" -newer /tmp/.dashboard-timestamp 2>/dev/null -exec tail -1 {} \; | head -3 | sed 's/^/  /' || echo "  None"
    touch /tmp/.dashboard-timestamp
    echo ""
    
    echo "Press Ctrl+C to exit. Refreshing in 10 seconds..."
    sleep 10
done
SCRIPT_EOF

