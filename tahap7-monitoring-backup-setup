#!/bin/bash

################################################################################
# TAHAP 7: Monitoring, Logging, Backup, dan Health Check Setup
# Ubuntu 24.04 LTS
#
# Script ini mengkonfigurasi:
# - System monitoring tools (htop, glances, iotop)
# - Log aggregation dan rotation
# - Backup scripts untuk configs dan data
# - Health check monitoring
# - Automated backup scheduling
# - Alert notifications setup
#
# Usage: bash tahap7-monitoring-backup-setup.sh
################################################################################

set -e

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Functions
print_header() {
    echo -e "\n${BLUE}===============================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}===============================================${NC}\n"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${CYAN}ℹ $1${NC}"
}

# Check if running with appropriate privileges
if [[ $EUID -ne 0 ]]; then
    print_error "Script ini harus dijalankan dengan sudo"
    exit 1
fi

print_header "TAHAP 7: Monitoring, Logging, Backup, dan Health Check Setup"

# ============================================================================
# SECTION 1: Collect Configuration Information
# ============================================================================
print_header "1. Informasi Konfigurasi"

# Get development user
read -p "Development user [default: devel_me]: " DEVEL_USER
DEVEL_USER=${DEVEL_USER:-devel_me}

if ! id "$DEVEL_USER" &>/dev/null; then
    print_error "User '$DEVEL_USER' tidak ditemukan"
    exit 1
fi

DEVEL_HOME=$(eval echo ~$DEVEL_USER)

print_success "Development user: $DEVEL_USER"
print_success "Home directory: $DEVEL_HOME"

# Get domain
read -p "Domain aplikasi [default: domainaplikasimu.id]: " DOMAIN
DOMAIN=${DOMAIN:-domainaplikasimu.id}

print_success "Domain: $DOMAIN"

# Get email untuk notifications
read -p "Email untuk notifikasi monitoring [default: admin@$DOMAIN]: " ALERT_EMAIL
ALERT_EMAIL=${ALERT_EMAIL:-admin@$DOMAIN}

print_success "Alert email: $ALERT_EMAIL"

# Get backup retention days
read -p "Hari backup retention [default: 30]: " BACKUP_RETENTION
BACKUP_RETENTION=${BACKUP_RETENTION:-30}

print_success "Backup retention: $BACKUP_RETENTION hari"

# ============================================================================
# SECTION 2: Install Monitoring Tools
# ============================================================================
print_header "2. Install System Monitoring Tools"

apt-get update > /dev/null 2>&1

# Install monitoring tools
TOOLS_TO_INSTALL="htop iotop nethogs curl wget ncdu"

echo "Installing monitoring tools..."
apt-get install -y $TOOLS_TO_INSTALL > /dev/null 2>&1

print_success "Monitoring tools installed: $TOOLS_TO_INSTALL"

# Install glances (advanced monitoring)
apt-get install -y glances > /dev/null 2>&1
print_success "Glances installed"

# ============================================================================
# SECTION 3: Create Monitoring Scripts
# ============================================================================
print_header "3. Create System Monitoring Scripts"

# System health check script
cat > "$DEVEL_HOME/health-check.sh" << 'SCRIPT_EOF'
#!/bin/bash
# System health check script

echo "========================================"
echo "System Health Check Report"
echo "Generated: $(date)"
echo "========================================"
echo ""

# Uptime
echo "1. System Uptime"
uptime | sed 's/^/   /'
echo ""

# CPU Usage
echo "2. CPU Usage (top 5)"
ps aux --sort=-%cpu | head -6 | awk '{printf "   %-20s %s%%\n", $1, $3}' | tail -5
echo ""

# Memory Usage
echo "3. Memory Usage"
free -h | grep "Mem" | awk '{printf "   Total: %s, Used: %s, Free: %s (%.1f%%)\n", $2, $3, $4, ($3/$2)*100}'
echo ""

# Disk Usage
echo "4. Disk Usage"
df -h / | tail -1 | awk '{printf "   Used: %s/%s (%.1f%%)\n", $3, $2, ($3/$2)*100}'
echo ""

# Network Status
echo "5. Network Connections"
ss -s | sed 's/^/   /'
echo ""

# Nginx Status
echo "6. Nginx Status"
systemctl is-active nginx > /dev/null 2>&1 && echo "   ✓ Running" || echo "   ✗ Not Running"
echo ""

# PM2 Status
echo "7. PM2 Applications"
pm2 list 2>/dev/null | tail -1 || echo "   PM2 not running"
echo ""

# Failed Services
echo "8. Failed System Services"
systemctl --failed --no-pager | tail -1 | sed 's/^/   /' || echo "   None"
echo ""

# SSL Certificates Expiry
echo "9. SSL Certificate Status"
for cert in /etc/letsencrypt/live/*/fullchain.pem; do
    if [ -f "$cert" ]; then
        domain=$(basename $(dirname "$cert"))
        expiry=$(openssl x509 -in "$cert" -noout -enddate | cut -d= -f2)
        days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
        if [ $days_left -lt 30 ]; then
            echo "   ⚠ $domain (expires in $days_left days)"
        else
            echo "   ✓ $domain (expires in $days_left days)"
        fi
    fi
done
echo ""

# Load Average
echo "10. System Load Average"
load=$(cat /proc/loadavg | awk '{print $1, $2, $3}')
echo "   $load"
SCRIPT_EOF

chmod +x "$DEVEL_HOME/health-check.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/health-check.sh"

print_success "Health check script created"

# System resources monitoring script
cat > "$DEVEL_HOME/resource-monitor.sh" << 'SCRIPT_EOF'
#!/bin/bash
# Resource monitoring script

INTERVAL=${1:-5}
DURATION=${2:-60}

echo "Resource Monitoring (interval: ${INTERVAL}s, duration: ${DURATION}s)"
echo "========================================"

END=$((SECONDS + DURATION))

while [ $SECONDS -lt $END ]; do
    clear
    echo "Resource Monitoring Report - $(date '+%Y-%m-%d %H:%M:%S')"
    echo "========================================"
    echo ""
    
    # CPU and Memory
    echo "CPU and Memory Usage:"
    free -h | grep Mem | awk '{printf "  Memory: %s/%s (%.1f%%)\n", $3, $2, ($3/$2)*100}'
    echo ""
    
    # Top processes by CPU
    echo "Top 5 Processes by CPU:"
    ps aux --sort=-%cpu | head -6 | tail -5 | awk '{printf "  %-20s CPU: %5.1f%% MEM: %5.1f%%\n", $1, $3, $4}'
    echo ""
    
    # Top processes by Memory
    echo "Top 5 Processes by Memory:"
    ps aux --sort=-%mem | head -6 | tail -5 | awk '{printf "  %-20s MEM: %5.1f%% CPU: %5.1f%%\n", $1, $4, $3}'
    echo ""
    
    # Disk I/O (if iotop available)
    if command -v iotop &> /dev/null; then
        echo "Disk I/O Activity:"
        iotop -b -n 1 2>/dev/null | head -5 | tail -3 | sed 's/^/  /'
    fi
    
    sleep $INTERVAL
done
SCRIPT_EOF

chmod +x "$DEVEL_HOME/resource-monitor.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/resource-monitor.sh"

print_success "Resource monitor script created"

# Application health check
cat > "$DEVEL_HOME/app-health-check.sh" << 'SCRIPT_EOF'
#!/bin/bash
# Check health of all applications

DOMAIN=${1:-domainaplikasimu.id}

echo "Application Health Check"
echo "========================================"
echo "Domain: $DOMAIN"
echo "Time: $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

# Check PM2 applications
echo "PM2 Applications Status:"
pm2 list 2>/dev/null || echo "  PM2 not running"
echo ""

# Check Nginx
echo "Nginx Status:"
systemctl is-active nginx > /dev/null 2>&1 && echo "  ✓ Running" || echo "  ✗ Not Running"
echo ""

# Check main domain HTTPS
echo "HTTPS Endpoint Tests:"
for i in {1..5}; do
    app_name="aplikasi$i"
    url="https://${app_name}.${DOMAIN}"
    
    response=$(curl -s -o /dev/null -w "%{http_code}" -m 5 "$url" 2>/dev/null)
    
    if [ "$response" = "200" ] || [ "$response" = "301" ] || [ "$response" = "302" ]; then
        echo "  ✓ $url (HTTP $response)"
    else
        echo "  ✗ $url (HTTP $response)"
    fi
done
SCRIPT_EOF

chmod +x "$DEVEL_HOME/app-health-check.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/app-health-check.sh"

print_success "Application health check script created"

# ============================================================================
# SECTION 4: Create Backup Scripts
# ============================================================================
print_header "4. Create Backup Scripts"

BACKUP_DIR="/backup/vps-${DOMAIN}"
mkdir -p "$BACKUP_DIR"
mkdir -p "$BACKUP_DIR/configs"
mkdir -p "$BACKUP_DIR/pm2"
mkdir -p "$BACKUP_DIR/apps"

print_success "Backup directories created: $BACKUP_DIR"

# Full system backup script
cat > "$DEVEL_HOME/backup-configs.sh" << EOFBACKUP
#!/bin/bash
# Backup important configurations

BACKUP_DIR="$BACKUP_DIR"
TIMESTAMP=\$(date +%Y%m%d_%H%M%S)
DOMAIN="$DOMAIN"
RETENTION_DAYS=$BACKUP_RETENTION

echo "Starting configuration backup..."
echo "Timestamp: \$TIMESTAMP"
echo ""

# Backup Nginx configs
echo "[1/5] Backing up Nginx configuration..."
tar -czf "\$BACKUP_DIR/configs/nginx-\$TIMESTAMP.tar.gz" /etc/nginx 2>/dev/null
echo "  ✓ Nginx configs backed up"

# Backup PM2 configs
echo "[2/5] Backing up PM2 configurations..."
tar -czf "\$BACKUP_DIR/pm2/pm2-configs-\$TIMESTAMP.tar.gz" $DEVEL_HOME/pm2-configs 2>/dev/null
echo "  ✓ PM2 configs backed up"

# Backup PM2 process list
echo "[3/5] Backing up PM2 process list..."
pm2 save > /dev/null 2>&1
cp \$HOME/.pm2/dump.pm2 "\$BACKUP_DIR/pm2/pm2-dump-\$TIMESTAMP.json" 2>/dev/null
echo "  ✓ PM2 dump backed up"

# Backup application .env files
echo "[4/5] Backing up application environment files..."
find $DEVEL_HOME/apps -name ".env*" -type f | tar -czf "\$BACKUP_DIR/apps/env-files-\$TIMESTAMP.tar.gz" --files-from - 2>/dev/null
echo "  ✓ Application .env files backed up"

# Backup SSL certificates
echo "[5/5] Backing up SSL certificates..."
if [ -d /etc/letsencrypt ]; then
    tar -czf "\$BACKUP_DIR/configs/ssl-certs-\$TIMESTAMP.tar.gz" /etc/letsencrypt 2>/dev/null
    echo "  ✓ SSL certificates backed up"
fi

echo ""
echo "Backup completed successfully!"
echo "Location: \$BACKUP_DIR"
echo ""

# Cleanup old backups
echo "Cleaning up old backups (retention: \$RETENTION_DAYS days)..."
find "\$BACKUP_DIR" -type f -mtime +\$RETENTION_DAYS -delete

echo "Backup process finished"
EOFBACKUP

chmod +x "$DEVEL_HOME/backup-configs.sh"
chown "$DEVEL_USER:$DEVEL_USER" "$DEVEL_HOME/backup-configs.sh"

print_success "Backup configs script created"

# Database backup template
cat > "$DEVEL_HOME/backup-database.sh" << 'EOFDB'
#!/bin/bash
